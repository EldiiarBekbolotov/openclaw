# Environment Variables for Hack United Sponsorship Outreach System
# Copy this file to .env and fill in your actual values

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_MIXTRAL=mixtral-8x7b-32768
GROQ_MODEL_LLAMA=llama3-8b-8192

# Google Sheets Configuration
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_WORKSHEET_NAME=Leads

# Gmail SMTP Configuration
GMAIL_USERNAME=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Railway/Deployment Configuration
RAILWAY_STATIC_URL=https://your-app.railway.app
NETLIFY_SITE_URL=https://your-site.netlify.app

# Logging Configuration
LOG_LEVEL=INFO